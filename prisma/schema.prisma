datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Book {
  id            Int       @id @default(autoincrement())
  slug          String
  name          String
  shortName     String
  testament     String    // "Old" or "New"
  genre         String    // "Pentateuch", "Historical", "Wisdom", "Prophets", "Deuterocanon", "Gospels", "Acts", "Epistles", "Revelation"
  order         Int       // 1 to 73
  language      String    @default("en") // "en" or "zh"
  chaptersCount Int
  chapters      Chapter[]

  @@unique([slug, language])
  @@unique([name, language])
  @@unique([order, language])
}

model Chapter {
  id          Int     @id @default(autoincrement())
  bookId      Int
  number      Int     // Chapter number (1, 2, 3...)
  versesCount Int
  book        Book    @relation(fields: [bookId], references: [id], onDelete: Cascade)
  verses      Verse[]

  @@unique([bookId, number])
}

model Verse {
  id         Int     @id @default(autoincrement())
  chapterId  Int
  number     Int     // Verse number (1, 2, 3...)
  text       String  // Verse content
  bookSlug   String  // De-normalized book slug for rapid querying
  chapterNum Int     // De-normalized chapter number for rapid querying
  language   String  @default("en") // De-normalized language for rapid querying
  chapter    Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([chapterId, number])
  @@index([language, bookSlug, chapterNum, number])
}
