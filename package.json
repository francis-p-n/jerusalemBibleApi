{
  "name": "jerusalem-bible-api",
  "version": "1.0.0",
  "description": "Production-grade, highly performant Jerusalem Bible API (73 Catholic Books canonical schema)",
  "main": "dist/index.js",
  "scripts": {
    "build": "npx prisma generate && rimraf dist && tsc && node scripts/copy-assets.js",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma db push",
    "prisma:seed": "ts-node prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "scrape": "ts-node scripts/scrape.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.4.0",
    "axios": "^1.16.1",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/cheerio": "^0.22.35",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.1",
    "prisma": "^6.4.0",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2"
  }
}
